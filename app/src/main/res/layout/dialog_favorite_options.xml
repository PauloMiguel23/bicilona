<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_info_window"
    android:padding="12dp"
    android:minWidth="160dp">

    <!-- Favorite name -->
    <TextView
        android:id="@+id/tvFavTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center">

        <!-- Set as destination (directions arrow) -->
        <ImageView
            android:id="@+id/btnSetDestination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_directions"
            android:adjustViewBounds="true"
            android:paddingVertical="6dp"
            android:paddingHorizontal="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/set_as_destination" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="#D0D0D0" />

        <!-- Remove from favorites -->
        <TextView
            android:id="@+id/btnRemoveFavorite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑️"
            android:textSize="24sp"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
